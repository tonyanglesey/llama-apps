# llama-apps control plane — copy to .env (gitignored) and fill in.
#
# State lives in the `deploy` schema of your Postgres. Point PG_* at it. For local
# dev that's usually localhost; if Postgres lives on another box, tunnel to it:
#   ssh -N -L 5433:localhost:5432 user@your-db-host
# then set PG_HOST=127.0.0.1 and PG_PORT=5433.
PORT=8787
HOST=127.0.0.1

PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=llama
PG_SCHEMA=deploy
PG_USER=postgres
PG_PASSWORD=__set_me__

# Caddy admin API — loopback only, never public.
CADDY_ADMIN=http://127.0.0.1:2019

# Deploy topology
DEPLOY_DOMAIN=apps.example.com
CONTAINER_PORT=3000

# GitHub webhook HMAC secret (must match the secret set on the repo webhook)
GITHUB_WEBHOOK_SECRET=__set_me__
