# llama-apps control plane — copy to .env (gitignored) and fill in.
#
# OSS model: nothing is hosted by lla.ma. Every server below is YOURS, wired up
# here. The control plane runs wherever you start it (your laptop, a VPS) and
# builds/runs deploys as Docker containers on that same host.

PORT=8787
HOST=127.0.0.1

# --- State database (required) -----------------------------------------------
# Project/deployment state lives in the `deploy` schema. Point PG_* at any
# Postgres you control: a local one, or an external box. If it's only reachable
# over SSH, tunnel first and point PG_HOST/PG_PORT at the local end:
#   ssh -N -L 5433:localhost:5432 user@your-db-host   ->   PG_HOST=127.0.0.1 PG_PORT=5433
# Apply the schema once:  psql ... -f control-plane/schema.sql
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=llama
PG_SCHEMA=deploy
PG_USER=postgres
PG_PASSWORD=__set_me__

# --- Builds (required) -------------------------------------------------------
# Deploys run as Docker containers on the host running this control plane, so
# Docker must be running and `nixpacks` installed. CONTAINER_PORT is the port
# your apps listen on inside the container.
CONTAINER_PORT=3000

# --- Public routing (OPTIONAL) -----------------------------------------------
# Leave CADDY_ADMIN unset for local dev: deploys are reachable directly at
# http://127.0.0.1:<port> (no public domain or TLS). To serve real public
# https://<app>.<domain>, run Caddy (see infra/) and set both of these:
# CADDY_ADMIN=http://127.0.0.1:2019
# DEPLOY_DOMAIN=apps.example.com

# --- GitHub (optional) -------------------------------------------------------
# Needed only for push-to-deploy webhooks and private repos.
# GITHUB_WEBHOOK_SECRET=__set_me__
# GITHUB_TOKEN=__set_me__

# Optional: refresh a project's dashboard thumbnail when a deploy goes live.
# Set to the capture command; leave unset to disable. Example:
#   SHOT_HOOK_CMD=node /path/to/llama-apps/scripts/capture-shots.mjs
